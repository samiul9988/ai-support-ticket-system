APP_NAME="AI Support Ticket System"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

FRONTEND_URL=http://localhost:3000

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ticket_system
DB_USERNAME=root
DB_PASSWORD=

QUEUE_CONNECTION=database

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_REQUEST_TIMEOUT=30
GEMINI_CONNECT_TIMEOUT=10
GEMINI_MAX_RETRIES=3
GEMINI_RETRY_DELAY_MS=1000
GEMINI_CIRCUIT_BREAKER=false
GEMINI_CIRCUIT_FAILURE_THRESHOLD=5
GEMINI_CIRCUIT_COOLDOWN=60
GEMINI_TEMPERATURE=0.7
GEMINI_MAX_OUTPUT_TOKENS=1024
GEMINI_TOP_P=0.95
AI_PROVIDER=gemini

AI_QUEUE_WORKERS=3
AI_QUEUE_TIMEOUT=45
AI_QUEUE_SLEEP=3
AI_QUEUE_MAX_PER_MINUTE=20
AI_QUEUE_RETRY_AFTER=120
